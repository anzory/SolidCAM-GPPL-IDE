{
  "comments": {
    "lineComment": ";"
  },
  "brackets": [
    ["(", ")"],
    ["[", "]"],
    ["{", "}"],
    ["<<", ">>"]
  ],
  "autoClosingPairs": [
    { "open": "(", "close": ")" },
    { "open": "[", "close": "]" },
    { "open": "{", "close": "}" },
    { "open": "'", "close": "'", "notIn": ["string"] },
    { "open": "\"", "close": "\"", "notIn": ["string"] }
  ],
  "surroundingPairs": [
    ["(", ")"],
    ["[", "]"],
    ["{", "}"],
    ["'", "'"],
    ["\"", "\""]
  ],
  "wordPattern": "[a-zA-Z][a-zA-Z0-9_]*",
  "indentationRules": {
    "increaseIndentPattern": "^\\s*(if|while|else|elseif)\\b.*$",
    "decreaseIndentPattern": "^\\s*(endif|endw|else|elseif|endp)\\b.*$"
  },
  "folding": {
    "markers": {
      "start": "^(?:@[a-zA-Z][a-zA-Z0-9_]*|\\s*;\\s*#region(?=\\s|$))",
      "end": "^(?:endp\\b|\\s*;\\s*#endregion(?=\\s|$))"
    }
  }
}
