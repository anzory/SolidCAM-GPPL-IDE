{
  "name": "vscode-gppl-ide",
  "displayName": "%displayName%",
  "description": "%description%",
  "version": "1.1.6",
  "publisher": "anzory",
  "author": {
    "name": "Andrey Zorin"
  },
  "icon": "images/icon.png",
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "https://github.com/anzory/SolidCAM-GPPL-IDE"
  },
  "l10n": "./l10n",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Snippets"
  ],
  "keywords": [
    "gppl",
    "solidcam",
    "postprocessor",
    "cnc",
    "gpp"
  ],
  "main": "./extension.js",
  "activationEvents": [],
  "contributes": {
    "languages": [
      {
        "id": "gppl",
        "aliases": [
          "GPPL",
          "SolidCAM GPPL",
          "General Post Processor Language"
        ],
        "extensions": [
          ".gpp"
        ],
        "icon": {
          "light": "./images/icon.png",
          "dark": "./images/icon.png"
        },
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "gppl",
        "scopeName": "source.gppl",
        "path": "./syntaxes/gppl.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "gppl",
        "path": "./snippets/gppl.code-snippets"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "%configuration.title%",
      "properties": {
        "solidcam-gppl.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "%configuration.trace.description%"
        },
        "gppl.encoding": {
          "type": "string",
          "enum": [
            "windows1252",
            "windows1251"
          ],
          "enumDescriptions": [
            "%configuration.encoding.windows1252%",
            "%configuration.encoding.windows1251%"
          ],
          "default": "windows1252",
          "description": "%configuration.encoding.description%"
        }
      }
    },
    "configurationDefaults": {
      "editor.semanticHighlighting.enabled": true,
      "[gppl]": {
        "editor.semanticHighlighting.enabled": true,
        "files.encoding": "windows1252",
        "files.autoGuessEncoding": false
      },
      "editor.semanticTokenColorCustomizations": {
        "rules": {
          "variable.readonly.defaultLibrary:gppl": {
            "fontStyle": "italic"
          },
          "variable.readonly.defaultLibrary.boolean:gppl": {
            "fontStyle": "italic underline"
          },
          "keyword.interrupt:gppl": {
            "foreground": "#ff4444"
          }
        }
      }
    },
    "semanticTokenScopes": [
      {
        "language": "gppl",
        "scopes": {
          "variable": [
            "variable.other.gppl"
          ],
          "variable.declaration": [
            "variable.other.declaration.gppl"
          ],
          "variable.readonly": [
            "variable.other.constant.gppl"
          ],
          "function": [
            "entity.name.function.gppl"
          ],
          "function.declaration": [
            "entity.name.function.definition.gppl"
          ],
          "parameter": [
            "variable.parameter.gppl"
          ],
          "parameter.declaration": [
            "variable.parameter.declaration.gppl"
          ],
          "namespace": [
            "entity.name.namespace.gppl"
          ],
          "class": [
            "entity.name.type.class.gppl"
          ]
        }
      }
    ],
    "commands": [
      {
        "command": "solidcam-gppl.openLogs",
        "title": "%command.openLogs.title%",
        "category": "SolidCAM GPPL"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "solidcam-gppl.openLogs"
        }
      ]
    }
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  }
}
