{
  "name": "vscode-gppl-ide",
  "displayName": "SolidCAM Postprocessor IDE",
  "description": "Language support for SolidCAM GPPL postprocessor files (.gpp)",
  "version": "0.6.3",
  "publisher": "anzory",
  "author": {
    "name": "Andrey Zorin"
  },
  "icon": "images/icon.png",
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "https://github.com/anzory/SolidCAM-GPPL-IDE"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Snippets"
  ],
  "keywords": [
    "gppl",
    "solidcam",
    "postprocessor",
    "cnc",
    "gpp"
  ],
  "main": "./extension.js",
  "activationEvents": [],
  "contributes": {
    "languages": [
      {
        "id": "gppl",
        "aliases": [
          "GPPL",
          "SolidCAM GPPL",
          "General Post Processor Language"
        ],
        "extensions": [
          ".gpp"
        ],
        "icon": {
          "light": "./images/icon.png",
          "dark": "./images/icon.png"
        },
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "gppl",
        "scopeName": "source.gppl",
        "path": "./syntaxes/gppl.tmLanguage.json"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "SolidCAM GPPL",
      "properties": {
        "solidcam-gppl.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Traces the communication between VS Code and the GPPL language server."
        },
        "gppl.encoding": {
          "type": "string",
          "enum": [
            "windows1252",
            "windows1251"
          ],
          "enumDescriptions": [
            "Windows-1252 (Western European, default ANSI on most systems)",
            "Windows-1251 (Cyrillic)"
          ],
          "default": "windows1252",
          "description": "Target encoding for .gpp files. SolidCAM runtime reads files in the system ANSI codepage. Diagnostic GPPL3001 warns about characters that cannot be represented in the selected encoding. This value should match files.encoding for [gppl]."
        }
      }
    },
    "configurationDefaults": {
      "editor.semanticHighlighting.enabled": true,
      "[gppl]": {
        "editor.semanticHighlighting.enabled": true,
        "files.encoding": "windows1252",
        "files.autoGuessEncoding": false
      },
      "editor.semanticTokenColorCustomizations": {
        "rules": {
          "variable.readonly.defaultLibrary:gppl": {
            "fontStyle": "italic"
          },
          "variable.readonly.defaultLibrary.boolean:gppl": {
            "fontStyle": "italic underline"
          },
          "keyword.interrupt:gppl": {
            "foreground": "#ff4444"
          }
        }
      }
    },
    "semanticTokenScopes": [
      {
        "language": "gppl",
        "scopes": {
          "variable": [
            "variable.other.gppl"
          ],
          "variable.declaration": [
            "variable.other.declaration.gppl"
          ],
          "variable.readonly": [
            "variable.other.constant.gppl"
          ],
          "function": [
            "entity.name.function.gppl"
          ],
          "function.declaration": [
            "entity.name.function.definition.gppl"
          ],
          "parameter": [
            "variable.parameter.gppl"
          ],
          "parameter.declaration": [
            "variable.parameter.declaration.gppl"
          ],
          "namespace": [
            "entity.name.namespace.gppl"
          ],
          "class": [
            "entity.name.type.class.gppl"
          ]
        }
      }
    ],
    "commands": [
      {
        "command": "solidcam-gppl.openLogs",
        "title": "SolidCAM GPPL: Open log file",
        "category": "SolidCAM GPPL"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "solidcam-gppl.openLogs"
        }
      ]
    }
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  }
}
