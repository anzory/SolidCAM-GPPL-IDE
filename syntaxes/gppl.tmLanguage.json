{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "GPPL",
  "scopeName": "source.gppl",
  "fileTypes": [
    "gpp"
  ],
  "patterns": [
    {
      "include": "#comment"
    },
    {
      "include": "#string"
    }
  ],
  "repository": {
    "comment": {
      "name": "comment.line.semicolon.gppl",
      "match": ";.*$"
    },
    "string": {
      "patterns": [
        {
          "name": "string.quoted.single.gppl",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.gppl",
              "match": "\\\\[\"'\\\\rntxh]"
            }
          ]
        },
        {
          "name": "string.quoted.double.gppl",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.gppl",
              "match": "\\\\[\"'\\\\rntxh]"
            }
          ]
        }
      ]
    }
  }
}
